---
import Layout from "@/layouts/layout.astro";
import FutureCalculator from "@/components/FutureCalculator";

const metadata = {
  title: "Comi Dólar | Tu Futuro",
  description: {
    meta: "Calculá qué materias del CBC de la UBA te corresponden por equivalencia automática al egresar de 5to año en el CNBA o Carlos Pellegrini y comparalo con cursar 6to año.",
    og: "Calculá qué materias del CBC de la UBA te corresponden por equivalencia automática al egresar de 5to año en el CNBA o Carlos Pellegrini y comparalo con cursar 6to año.",
  },
  canonical: "https://comidolar.com.ar/futuro",
  og: {
    image: "https://comidolar.com.ar/assets/img/opengraph/futuro.webp",
    video: "https://comidolar.com.ar/assets/img/opengraph/video.webm",
  },
};
---

<Layout bodyclass="pt-12" metadata={metadata}>
  <main class="space-y-8 max-w-screen-xl mx-auto px-4 text-center">
    <header class="space-y-2">
      <h1 class="text-5xl font-extrabold tracking-tight text-zinc-900 dark:text-white bg-gradient-to-r from-green-500 to-emerald-600 bg-clip-text text-transparent">
        Tu Futuro (CBC vs 6to Año)
      </h1>
      <p class="text-lg text-zinc-600 dark:text-zinc-400 max-w-2xl mx-auto">
        Según la resolución <strong>RESCS-2026-890-E-UBA-REC</strong>, conocé al instante cuántas materias del Ciclo Básico Común ya tenés aprobadas de forma automática al egresar de 5to año y compará el camino del CBC tradicional con cursar el 6to año optativo.
      </p>
    </header>

    <FutureCalculator client:load />
  </main>
</Layout>
